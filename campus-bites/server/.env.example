# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/campus-bites

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_this_to_a_random_string

# ─── CORS — Frontend Origin(s) ───────────────────────────────────────────────
# Comma-separated list of allowed origins. REQUIRED for cross-origin requests.
FRONTEND_URL=http://localhost:5173

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id

# ─── Razorpay Payment Gateway ────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── WhatsApp Integration (OpenWA Gateway) ───────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=http://localhost:2785/api
WHATSAPP_API_KEY=your_openwa_api_key
WHATSAPP_SESSION_ID=my-bot

# ─── Seed Script (only needed when running `node seedUsers.js`) ──────────────
# Use strong, unique passwords — these will be bcrypt-hashed on creation.
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_random_password
SEED_STAFF_EMAIL=staff@yourdomain.com
SEED_STAFF_PASSWORD=CHANGE_ME_strong_random_password
SEED_DELIVERY_EMAIL=delivery@yourdomain.com
SEED_DELIVERY_PASSWORD=CHANGE_ME_strong_random_password
SEED_STUDENT_EMAIL=student@yourdomain.com
SEED_STUDENT_PASSWORD=CHANGE_ME_strong_random_password
